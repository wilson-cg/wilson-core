# Wilson's Client Portal — environment variables
#
# Copy this file to .env for local development and fill in real values.
# On Railway, set these via the Variables tab on the service.

# ─── Database ────────────────────────────────────────────────
# Postgres connection string. On Railway, this is auto-injected when you
# attach a Postgres plugin to the app — you don't need to set it manually.
# Locally, point at any Postgres (Docker, Neon, or `railway run` to use
# Railway's DB from your shell).
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Optional. The Node environment Next.js runs in.
NODE_ENV="development"

# ─── Email (Resend) ──────────────────────────────────────────
# Required to actually send approval emails. If unset, Notification rows
# are still created with status=QUEUED but no email goes out (the system
# logs and continues without erroring).
RESEND_API_KEY="re_..."

# Optional. The "From" address used on outbound approval emails.
# Defaults to "Wilson's <approvals@wilsons.com>". The domain must be
# verified in Resend (DNS records) before sending will succeed.
RESEND_FROM_EMAIL="Wilson's <approvals@wilsons.com>"

# Optional. Public URL of the deployed app — used to build the CTA
# "Open the approval page" button in approval emails. Falls back to
# https://wilson-core-production.up.railway.app if not set.
APP_URL="https://wilson-core-production.up.railway.app"
