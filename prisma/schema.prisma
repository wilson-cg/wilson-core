// Wilson's Client Portal — data model
//
// v1 scope: approval + project management. No LinkedIn integration, no
// Unipile. Prospects are entered by Wilson's staff. Messages are drafted
// by staff, approved by clients, sent manually through the client's own
// LinkedIn session, and marked as sent/replied by staff.
//
// SQLite for dev + stress testing — swap to Postgres via provider change
// when we deploy. All queries are workspace-scoped (see lib/scope.ts).

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── Users & access ─────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  // Auth.js standard fields. We make `name` optional to satisfy the Prisma
  // adapter contract (Auth.js may create rows from email-only sign-in before
  // the user picks a name). `emailVerified` and `image` are required by the
  // adapter even if we don't surface them in the UI.
  name          String?
  emailVerified DateTime?
  image         String?
  role          SystemRole @default(CLIENT)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  memberships Membership[]
  accounts    Account[]
  sessions    Session[]
  invitesSent Invite[]     @relation("InviteSender")

  draftedMessages   Message[]      @relation("Drafter")
  approvedMessages  Message[]      @relation("Approver")
  sentMessages      Message[]      @relation("Sender")
  assignedProspects Prospect[]     @relation("Assignee")
  events            MessageEvent[]

  draftedPosts  Post[]      @relation("PostDrafter")
  approvedPosts Post[]      @relation("PostApprover")
  postedPosts   Post[]      @relation("PostPoster")
  postEvents    PostEvent[]

  prospectEvents ProspectEvent[]
}

// ─── Auth.js v5 (Prisma adapter) ────────────────────────────────
// Field shapes copied verbatim from https://authjs.dev/getting-started/adapters/prisma
// Do not improvise field names — the adapter looks them up by exact name.

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Invites ────────────────────────────────────────────────────
// Pending invitation. The signIn callback in lib/auth.ts gates new sign-ins
// on the existence of a matching invite row, and events.createUser accepts
// it (sets systemRole, creates membership when workspace-scoped) on first
// successful sign-in.

model Invite {
  id            String         @id @default(cuid())
  email         String
  token         String         @unique
  systemRole    SystemRole
  workspaceId   String?
  workspace     Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceRole WorkspaceRole?
  // Granular permission preset baked into the invite. Applied to the new
  // Membership row when the invitee accepts.
  canApprove    Boolean        @default(false)
  canEdit       Boolean        @default(false)
  canSend       Boolean        @default(false)
  canAdmin      Boolean        @default(false)
  // Notification preferences carried through to Membership at acceptance time.
  notifyOnNewProspect      Boolean @default(false)
  notifyOnStatusChange     Boolean @default(false)
  notifyOnComment          Boolean @default(false)
  invitedById   String
  invitedBy     User           @relation("InviteSender", fields: [invitedById], references: [id])
  expiresAt     DateTime
  acceptedAt    DateTime?
  createdAt     DateTime       @default(now())

  workspaceAccesses InviteWorkspaceAccess[]

  @@index([email])
  @@index([workspaceId])
  @@index([token])
}

// Multi-workspace invite access. Lets the /dashboard/team flow grant a
// teammate N memberships at invite time. Legacy single-workspace invites
// (Invite.workspaceId/workspaceRole) still work — events.createUser fans
// both shapes into Membership rows.
model InviteWorkspaceAccess {
  id            String        @id @default(cuid())
  inviteId      String
  workspaceId   String
  workspaceRole WorkspaceRole
  // Per-workspace permission preset for multi-workspace invites.
  canApprove    Boolean       @default(false)
  canEdit       Boolean       @default(false)
  canSend       Boolean       @default(false)
  canAdmin      Boolean       @default(false)
  // Notification preferences carried through to Membership at acceptance time.
  notifyOnNewProspect      Boolean @default(false)
  notifyOnStatusChange     Boolean @default(false)
  notifyOnComment          Boolean @default(false)

  invite    Invite    @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([inviteId, workspaceId])
  @@index([inviteId])
  @@index([workspaceId])
}

enum SystemRole {
  ADMIN // Wilson's agency admin
  TEAM_MEMBER // Wilson's team member
  CLIENT // External client user
}

model Membership {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole
  // Granular per-action permissions (V1 UX overhaul, 2026-05-01).
  // canView is implicit: every Membership row implies View access.
  // canApprove → toggle ICP fits, set approver decision, write approver notes.
  // canEdit    → capture/edit prospect fields, archive/unarchive, draft messages.
  // canSend    → mark sent/replied/meeting-booked, edit outcome fields.
  // canAdmin   → workspace settings + members + danger zone.
  canApprove                   Boolean       @default(false)
  canEdit                      Boolean       @default(false)
  canSend                      Boolean       @default(false)
  canAdmin                     Boolean       @default(false)
  // Notifications preferences (Members modal → Notifications tab).
  // notifyOnApprovalRequested keeps its true default for backwards compat;
  // the three new flags default to false (opt-in) and get set per the
  // invite preset (Approver/Client = approvals only; Team = all four).
  notifyOnApprovalRequested    Boolean       @default(true)
  notifyOnNewProspect          Boolean       @default(false)
  notifyOnStatusChange         Boolean       @default(false)
  notifyOnComment              Boolean       @default(false)
  // True for the workspace's "Company Owner". Backfilled to the earliest
  // ADMIN membership per workspace; new owners must be set explicitly.
  isWorkspaceOwner             Boolean       @default(false)
  createdAt                    DateTime      @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@index([userId])
  @@index([workspaceId, role])
}

enum WorkspaceRole {
  ADMIN // Wilson's admin (full access, all workspaces — membership grants access)
  TEAM_MEMBER // Wilson's team member assigned to this workspace
  CLIENT // Client user (their own workspace only)
}

// ─── Workspaces ─────────────────────────────────────────────────

model Workspace {
  id              String   @id @default(cuid())
  name            String // Display name (e.g. "Condor Group")
  slug            String   @unique
  businessName    String? // Legal business name if different from display name
  contactName     String // Cached primary contact name (denormalized from ClientContact, for display)
  accentColor     String? // Optional white-label accent
  logoUrl         String? // URL or data: URL of the client's logo
  linkedinUrl     String? // Company LinkedIn page URL
  approvalEmail   String? // Override email for approval notifications. Falls back to primary contact's email.
  onboardingToken String?  @unique // Public-shareable token unlocking /onboard/[token]. Scoped to this workspace only.
  approvalToken   String?  @unique // Public-shareable token unlocking /approve/[token]. Used in approval emails so clients can approve/reject without logging in. Scoped to this workspace only.
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  memberships    Membership[]
  prospects      Prospect[]
  messages       Message[]
  events         MessageEvent[]
  icp            Icp?
  posts          Post[]
  postEvents     PostEvent[]
  notifications  Notification[]
  prospectEvents ProspectEvent[]
  contacts       ClientContact[]
  onboarding     OnboardingResponse[]
  invites        Invite[]
  inviteAccesses InviteWorkspaceAccess[]
}

model Icp {
  id          String   @id @default(cuid())
  workspaceId String   @unique
  summary     String // Ideal customer summary (free text)
  toneOfVoice String // Tone + dos/donts as markdown
  mustNotDo   String // Comma-separated must-nots
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── Prospects ──────────────────────────────────────────────────

model Prospect {
  id                  String             @id @default(cuid())
  workspaceId         String
  fullName            String
  linkedinUrl         String
  company             String
  title               String?
  email               String? // Optional; many prospects won't have an email known
  location            String? // Freeform city / region
  tags                String? // Comma-separated for v1 simplicity
  // V1 intent-tracking pivot — see CSV columns Signal Type / Post Engagement Context.
  signalType          SignalType?
  signalContext       String? // Free text: link or quote of the post / engagement.
  // ICP fit toggles + computed score (0–4). Recomputed in app code on every flip.
  icpCompanyFit       Boolean            @default(false)
  icpSeniorityFit     Boolean            @default(false)
  icpContextFit       Boolean            @default(false)
  icpGeographyFit     Boolean            @default(false)
  icpScore            Int                @default(0)
  approverDecision    ApproverDecision   @default(PENDING)
  messageAngle        String? // "keep casual", "met him at an event", etc.
  approverNotes       String? // Free text the approver writes (separate from internal notes).
  archived            Boolean            @default(false)
  status              ProspectStatus     @default(IDENTIFIED)
  assigneeId          String?
  notes               String? // Internal-only free text
  linkedinConnectedAt DateTime? // When we connected with them on LinkedIn
  lastContactedAt     DateTime? // Last outbound contact (editable, overrides derived)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignee  User?           @relation("Assignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  messages  Message[]
  events    ProspectEvent[]

  @@index([workspaceId])
  @@index([status])
  @@index([assigneeId])
  @@index([workspaceId, status, updatedAt])
}

// ─── Prospect activity timeline ────────────────────────────────
// Everything that isn't a formal portal action (draft/approve/send) —
// LinkedIn connections, external calls/emails, manual notes, custom logs.

model ProspectEvent {
  id          String            @id @default(cuid())
  prospectId  String
  workspaceId String
  actorId     String
  eventType   ProspectEventType
  note        String?
  occurredAt  DateTime // Real-world date the event happened
  createdAt   DateTime          @default(now())

  prospect  Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User      @relation(fields: [actorId], references: [id])

  @@index([prospectId])
  @@index([workspaceId])
  @@index([prospectId, occurredAt])
}

enum ProspectEventType {
  ADDED
  LINKEDIN_CONNECTION_SENT
  LINKEDIN_CONNECTION_ACCEPTED
  CONTACTED
  CALL
  EMAIL
  MEETING
  NOTE_ADDED
  CUSTOM
}

enum SignalType {
  REACTION
  COMMENT
  CONNECTION_REQUEST
  POST
  REPEATED_ENGAGEMENT
  CUSTOM
}

enum ApproverDecision {
  PENDING
  APPROVED
  DECLINED
}

enum ProspectStatus {
  IDENTIFIED
  NEEDS_APPROVER_DECISION
  MESSAGE_DRAFTED
  PENDING_APPROVAL
  APPROVED
  SENT
  REPLIED
  MEETING_BOOKED
  NOT_INTERESTED
  NURTURE
}

// ─── Messages ───────────────────────────────────────────────────

model Message {
  id            String        @id @default(cuid())
  workspaceId   String
  prospectId    String
  body          String
  status        MessageStatus @default(DRAFT)
  version       Int           @default(1)
  drafterId     String
  approverId    String? // Client user who approved
  approvedAt    DateTime?
  senderId      String? // Team member who marked sent
  sentAt        DateTime?
  repliedAt     DateTime? // Set when team marks replied
  rejectionNote String? // Client's rejection note if any
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prospect  Prospect       @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  drafter   User           @relation("Drafter", fields: [drafterId], references: [id])
  approver  User?          @relation("Approver", fields: [approverId], references: [id], onDelete: SetNull)
  sender    User?          @relation("Sender", fields: [senderId], references: [id], onDelete: SetNull)
  events    MessageEvent[]

  @@index([workspaceId])
  @@index([prospectId])
  @@index([status])
  @@index([workspaceId, status, updatedAt])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, approvedAt])
  @@index([workspaceId, sentAt])
  @@index([workspaceId, repliedAt])
}

enum MessageStatus {
  DRAFT // Team is still working on it
  PENDING_APPROVAL // Submitted to client
  APPROVED // Client approved
  REJECTED // Client rejected (with note)
  SENT // Team marked sent
  REPLIED // Team marked replied
}

// ─── Audit trail ────────────────────────────────────────────────

model MessageEvent {
  id          String    @id @default(cuid())
  messageId   String
  workspaceId String
  actorId     String
  eventType   EventType
  metadata    String? // JSON blob for diffs, notes, etc.
  createdAt   DateTime  @default(now())

  message   Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User      @relation(fields: [actorId], references: [id])

  @@index([messageId])
  @@index([workspaceId])
  @@index([workspaceId, eventType, createdAt])
}

enum EventType {
  DRAFTED
  SUBMITTED_FOR_APPROVAL
  APPROVED
  EDITED_AND_APPROVED
  REJECTED
  SENT
  REPLIED
  STATUS_CHANGED
  NOTE_ADDED
}

// ─── Content posts ──────────────────────────────────────────────
// LinkedIn posts drafted by the team, approved by the client, then posted
// manually from the client's own LinkedIn account. Parallel to Message
// but attached directly to the Workspace — content is about the client's
// feed, not about a specific prospect.

model Post {
  id            String     @id @default(cuid())
  workspaceId   String
  title         String? // Internal label only, not posted
  body          String
  status        PostStatus @default(DRAFT)
  version       Int        @default(1)
  drafterId     String
  approverId    String?
  approvedAt    DateTime?
  posterId      String? // Team member who confirmed the post went up
  postedAt      DateTime?
  postedUrl     String? // Optional link to the actual LinkedIn post
  rejectionNote String?
  scheduledFor  DateTime? // Optional target date
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  drafter   User        @relation("PostDrafter", fields: [drafterId], references: [id])
  approver  User?       @relation("PostApprover", fields: [approverId], references: [id], onDelete: SetNull)
  poster    User?       @relation("PostPoster", fields: [posterId], references: [id], onDelete: SetNull)
  events    PostEvent[]
  media     PostMedia[]

  @@index([workspaceId])
  @@index([status])
  @@index([workspaceId, status, updatedAt])
  @@index([workspaceId, postedAt])
}

// Images / media attached to a post. Goes through the same approval flow
// as the body — clients see attachments in the approval card and can
// reject if anything's off.
model PostMedia {
  id          String   @id @default(cuid())
  postId      String
  // Data URL or external URL. Kept simple for v1 — swap to Cloudflare R2
  // / Railway volume when files get bigger or volume increases.
  url         String   @db.Text
  filename    String?
  contentType String?
  width       Int?
  height      Int?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

enum PostStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  POSTED
}

model PostEvent {
  id          String        @id @default(cuid())
  postId      String
  workspaceId String
  actorId     String
  eventType   PostEventType
  metadata    String?
  createdAt   DateTime      @default(now())

  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor     User      @relation(fields: [actorId], references: [id])

  @@index([postId])
  @@index([workspaceId])
  @@index([workspaceId, eventType, createdAt])
}

enum PostEventType {
  DRAFTED
  EDITED
  SUBMITTED_FOR_APPROVAL
  APPROVED
  EDITED_AND_APPROVED
  REJECTED
  POSTED
}

// ─── Notifications ──────────────────────────────────────────────
// Mock notification outbox. When a team member submits a draft for client
// approval (message or post), we queue a Notification row describing what
// WOULD be sent over email/Slack. Real delivery wires up later (Resend +
// Slack webhook) — for stress testing, the portal shows the outbox so you
// can see the notification would fire.

model Notification {
  id          String              @id @default(cuid())
  workspaceId String
  channel     NotificationChannel
  recipient   String // email address or @handle
  subject     String
  body        String
  relatedType String? // "message" | "post"
  relatedId   String?
  status      NotificationStatus  @default(QUEUED)
  sentAt      DateTime?
  createdAt   DateTime            @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([status])
}

enum NotificationChannel {
  EMAIL
  SLACK
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

// ─── Client onboarding ──────────────────────────────────────────
// A workspace can have multiple client contacts (founder + EA + co-founder
// is common). Exactly one is marked primary — that contact's email is the
// default approval recipient if workspace.approvalEmail isn't set.

model ClientContact {
  id          String   @id @default(cuid())
  workspaceId String
  fullName    String
  title       String?
  email       String?
  linkedinUrl String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, isPrimary, createdAt])
}

// Onboarding questionnaire — Q&A rows per workspace, edited like a sheet.
// Default questions seeded on workspace creation; can be added/removed/
// reordered/edited freely afterwards.

model OnboardingResponse {
  id            String              @id @default(cuid())
  workspaceId   String
  question      String
  // For TEXT/LONGTEXT/URL/NUMBER: plain string. For SINGLE_CHOICE: the
  // selected option label. For MULTI_CHOICE: a JSON array of selected
  // option labels (e.g. ["Direct","Warm","Funny"]).
  answer        String?
  fieldType     OnboardingFieldType @default(LONGTEXT)
  // Pipe-separated list of options for SINGLE_CHOICE / MULTI_CHOICE.
  // Null for free-text fields.
  options       String?
  // For MULTI_CHOICE — minimum / maximum number of selectable options.
  minSelections Int?
  maxSelections Int?
  orderIndex    Int                 @default(0)
  required      Boolean             @default(false)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, orderIndex])
}

enum OnboardingFieldType {
  TEXT
  LONGTEXT
  URL
  NUMBER
  SINGLE_CHOICE
  MULTI_CHOICE
}
